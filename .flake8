[flake8]
# stop the build if there are Python syntax errors or undefined names
select = E9,F63,F7,F82
show-source = True
statistics = True
count = True
max-complexity = 10
max-line-length = 127
# allow exit-zero to treat all errors as warnings if needed, but here we want strict selective checks
# exclude = .git,__pycache__,docs,old,build,dist
