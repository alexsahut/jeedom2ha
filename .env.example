# Environment variables for jeedom2ha daemon tests
# Copy this file to .env and fill in your values.

# Daemon HTTP API (local, 127.0.0.1 only)
DAEMON_HOST=127.0.0.1
DAEMON_PORT=8765
DAEMON_LOCAL_SECRET=changeme

# MQTT Broker (for integration tests)
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# Jeedom core API (for integration tests)
JEEDOM_API_URL=http://127.0.0.1/core/api/jeeApi.php
JEEDOM_API_KEY=changeme

# Test environment identifier
TEST_ENV=local

# -----------------------------------------------------------------------
# DEV/TEST deploy — scripts/deploy-to-box.sh (local test box only)
# NOT used in the canonical release cycle (Jeedom Market).
# -----------------------------------------------------------------------
JEEDOM_BOX_HOST=192.168.1.x           # IP/hostname de la box de test
JEEDOM_BOX_USER=asahut                # Utilisateur SSH (pas de root direct sur Jeedom standard)
JEEDOM_BOX_PORT=22                    # Port SSH
JEEDOM_BOX_PATH=/var/www/html/plugins/jeedom2ha     # Chemin exact (ne pas modifier)
JEEDOM_STAGING_DIR=/home/asahut/jeedom2ha-staging   # Staging intermédiaire (writable par JEEDOM_BOX_USER)
# JEEDOM_ROOT=/var/www/html           # Override si Jeedom installé ailleurs
